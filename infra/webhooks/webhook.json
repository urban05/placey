[
  {
    "id": "deploy-placey",
    "execute-command": "/opt/placey/infra/server/deploy.sh",
    "command-working-directory": "/opt/placey",
    "response-message": "Deploying...",
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "{{WEBHOOKSECRET}}",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature-256"
        }
      }
    }
  }
]
